{
  "id": "yad",
  "name": "Yad",
  "description": "Integration with Yandex Mail, Calendar, Disk and Contacts via app passwords",
  "contracts": {
    "tools": [
      "yad_disk_list",
      "yad_disk_info",
      "yad_disk_upload",
      "yad_disk_download",
      "yad_disk_mkdir",
      "yad_disk_delete",
      "yad_disk_move",
      "yad_disk_copy",
      "yad_disk_publish",
      "yad_mail_list",
      "yad_mail_read",
      "yad_mail_send",
      "yad_mail_search",
      "yad_calendar_list",
      "yad_calendar_events",
      "yad_calendar_create_event",
      "yad_calendar_update_event",
      "yad_calendar_delete_event",
      "yad_contacts_list",
      "yad_contacts_get",
      "yad_contacts_create",
      "yad_contacts_update",
      "yad_contacts_delete"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "login": {
        "type": "string",
        "description": "Yandex login (e.g. user or user@yandex.ru)"
      },
      "mail_app_password": {
        "type": ["string", "object"],
        "description": "App password for Mail (type: 'Почта')"
      },
      "calendar_app_password": {
        "type": ["string", "object"],
        "description": "App password for Calendar (type: 'Календари')"
      },
      "disk_app_password": {
        "type": ["string", "object"],
        "description": "App password for Disk (type: 'Файлы')"
      },
      "contacts_app_password": {
        "type": ["string", "object"],
        "description": "App password for Contacts (type: 'Контакты')"
      }
    },
    "required": ["login"]
  },
  "uiHints": {
    "login": {
      "label": "Yandex Login",
      "help": "Your Yandex username or full email (e.g. user@yandex.ru)",
      "placeholder": "user@yandex.ru"
    },
    "mail_app_password": {
      "label": "Mail App Password",
      "help": "Create at id.yandex.ru/security/app-passwords, type 'Почта'",
      "sensitive": true,
      "placeholder": "xxxx-xxxx-xxxx-xxxx"
    },
    "calendar_app_password": {
      "label": "Calendar App Password",
      "help": "Create at id.yandex.ru/security/app-passwords, type 'Календари'",
      "sensitive": true,
      "placeholder": "xxxx-xxxx-xxxx-xxxx"
    },
    "disk_app_password": {
      "label": "Disk App Password",
      "help": "Create at id.yandex.ru/security/app-passwords, type 'Файлы'",
      "sensitive": true,
      "placeholder": "xxxx-xxxx-xxxx-xxxx"
    },
    "contacts_app_password": {
      "label": "Contacts App Password",
      "help": "Create at id.yandex.ru/security/app-passwords, type 'Контакты'",
      "sensitive": true,
      "placeholder": "xxxx-xxxx-xxxx-xxxx"
    }
  }
}
